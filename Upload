import org.junit.jupiter.api.Test;
import java.util.List;
import java.util.regex.Pattern;

import static org.junit.jupiter.api.Assertions.*;

class BicFiValidationTest {

    private static final String REGEX =
            "^(?=(?:.*[A-Za-z]){6,})[A-Za-z][A-Za-z0-9]{7}([A-Za-z0-9]{3})?$";

    private final Pattern pattern = Pattern.compile(REGEX);

    @Test
    void testValidAndInvalidBicFi() {

        List<String> validBicFi = List.of(
                "CITIGB22",        // 8 characters
                "CITIGB22XXX",     // 11 characters
                "HDFCINBB",        // 8 characters
                "HDFCINBBXXX",     // 11 characters
                "DEUTDEFF500"      // 11 characters
        );

        List<String> invalidBicFi = List.of(
                "1ITIGB22",        // Does not start with alphabet
                "CITI1222",        // Less than 6 alphabets
                "CITIGB2",         // Less than 8 characters
                "CITIGB22XX",      // 10 characters (invalid length)
                "12345678",        // No alphabets
                "CITIGB22XXXX"     // 12 characters
        );

        validBicFi.forEach(input ->
                assertTrue(pattern.matcher(input).matches(),
                        "Expected valid but failed: " + input)
        );

        invalidBicFi.forEach(input ->
                assertFalse(pattern.matcher(input).matches(),
                        "Expected invalid but passed: " + input)
        );
    }
}