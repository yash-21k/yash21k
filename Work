import org.apache.beam.sdk.transforms.DoFnTester;
import org.junit.Test;

import com.google.pubsub.v1.PubsubMessage;

import java.nio.charset.StandardCharsets;
import java.nio.file.Files;
import java.nio.file.Paths;
import java.util.HashMap;

import static org.mockito.Mockito.*;

public class ProcessorTest {

    @Test
    public void testProcessor_withDedupAndMgmtEnrichment() throws Exception {

        // 1. Read payload from file (no attributes)
        String payload = Files.readString(
                Paths.get("src/test/resources/input.json")
        );

        // 2. Convert to PubsubMessage
        PubsubMessage raw =
                PubsubMessage.newBuilder()
                        .setData(
                                com.google.protobuf.ByteString.copyFromUtf8(payload)
                        )
                        .putAllAttributes(new HashMap<>())
                        .build();

        // 3. Mock Bigtable (if dedup uses it)
        BigtableClient mockBigtable = mock(BigtableClient.class);
        when(mockBigtable.exists(any())).thenReturn(false);

        // 4. Run Dedup DoFn
        DoFnTester<PubsubMessage, PubsubMessage> dedupTester =
                DoFnTester.of(new DedupDoFn(mockBigtable));

        PubsubMessage afterDedup =
                dedupTester.processBundle(raw).get(0);

        // 5. Run Mgmt DoFn
        DoFnTester<PubsubMessage, PubsubMessage> mgmtTester =
                DoFnTester.of(new MgmtDoFn());

        PubsubMessage enriched =
                mgmtTester.processBundle(afterDedup).get(0);

        // 6. Run processor
        Processor processor = new Processor();
        processor.process(enriched);

        // 7. Assertions (example)
        assert enriched.getAttributesMap().containsKey("timestamp");
    }
}