import com.google.cloud.storage.Blob;
import com.google.cloud.storage.Storage;
import com.google.cloud.storage.StorageOptions;
import org.springframework.core.env.PropertiesPropertySource;
import org.springframework.core.env.PropertySource;
import org.springframework.core.io.support.PropertySourceFactory;
import org.springframework.core.io.support.EncodedResource;

import java.io.ByteArrayInputStream;
import java.util.Properties;

public class GcsPropertySourceFactory implements PropertySourceFactory {

    @Override
    public PropertySource<?> createPropertySource(
            String name,
            EncodedResource resource) {

        try {
            String location = resource.getResource().getDescription();
            // expected: gcs:bucket/file.properties
            String path = location.replace("gcs:", "");
            String[] parts = path.split("/", 2);

            String bucket = parts[0];
            String file = parts[1];

            Storage storage = StorageOptions.getDefaultInstance().getService();
            Blob blob = storage.get(bucket, file);

            Properties props = new Properties();
            props.load(new ByteArrayInputStream(blob.getContent()));

            return new PropertiesPropertySource(file, props);

        } catch (Exception e) {
            throw new RuntimeException("Failed to load GCS property source", e);
        }
    }
}