import com.google.cloud.pubsub.v1.SubscriptionAdminClient;
import com.google.cloud.pubsub.v1.stub.SubscriberStub;
import com.google.cloud.pubsub.v1.stub.SubscriberStubSettings;
import com.google.protobuf.Timestamp;
import com.google.pubsub.v1.AcknowledgeRequest;
import com.google.pubsub.v1.ProjectSubscriptionName;
import com.google.pubsub.v1.PullRequest;
import com.google.pubsub.v1.PullResponse;
import com.google.pubsub.v1.ReceivedMessage;
import com.google.pubsub.v1.SeekRequest;

import java.util.ArrayList;
import java.util.List;

public class PubSubReplayMessages {

    private static final String PROJECT_ID = "YOUR_PROJECT_ID";
    private static final String SUBSCRIPTION_ID = "YOUR_SUBSCRIPTION";

    public static void main(String[] args) throws Exception {

        ProjectSubscriptionName subscriptionName =
                ProjectSubscriptionName.of(PROJECT_ID, SUBSCRIPTION_ID);

        // Step 1: Seek to the desired timestamp
        try (SubscriptionAdminClient adminClient = SubscriptionAdminClient.create()) {

            Timestamp timestamp = Timestamp.newBuilder()
                    .setSeconds(1753000000L) // Replace with your epoch seconds
                    .build();

            SeekRequest seekRequest = SeekRequest.newBuilder()
                    .setSubscription(subscriptionName.toString())
                    .setTime(timestamp)
                    .build();

            adminClient.seek(seekRequest);

            System.out.println("Seek completed.");
        }

        // Step 2: Pull messages
        SubscriberStubSettings settings = SubscriberStubSettings.newBuilder().build();

        try (SubscriberStub subscriber = SubscriberStub.create(settings)) {

            while (true) {

                PullRequest pullRequest = PullRequest.newBuilder()
                        .setSubscription(subscriptionName.toString())
                        .setMaxMessages(1000)
                        .build();

                PullResponse response = subscriber.pullCallable().call(pullRequest);

                if (response.getReceivedMessagesCount() == 0) {
                    System.out.println("No more messages.");
                    break;
                }

                List<String> ackIds = new ArrayList<>();

                for (ReceivedMessage receivedMessage : response.getReceivedMessagesList()) {

                    System.out.println("----------------------------------");
                    System.out.println("Message ID : " + receivedMessage.getMessage().getMessageId());
                    System.out.println("Publish Time : " + receivedMessage.getMessage().getPublishTime());
                    System.out.println("Data : " +
                            receivedMessage.getMessage().getData().toStringUtf8());

                    ackIds.add(receivedMessage.getAckId());
                }

                subscriber.acknowledgeCallable().call(
                        AcknowledgeRequest.newBuilder()
                                .setSubscription(subscriptionName.toString())
                                .addAllAckIds(ackIds)
                                .build());

                System.out.println("Acknowledged " + ackIds.size() + " messages.");
            }
        }

        System.out.println("Replay completed.");
    }
}