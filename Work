package com.example.pubsub;

import com.google.api.core.ApiFuture;
import com.google.cloud.pubsub.v1.AckReplyConsumer;
import com.google.cloud.pubsub.v1.MessageReceiver;
import com.google.cloud.pubsub.v1.Publisher;
import com.google.cloud.pubsub.v1.Subscriber;
import com.google.pubsub.v1.ProjectSubscriptionName;
import com.google.pubsub.v1.ProjectTopicName;
import com.google.pubsub.v1.PubsubMessage;

public class SubscriptionToTopic {

    private static final String PROJECT_ID = "your-project-id";
    private static final String SUBSCRIPTION_ID = "your-subscription-id";
    private static final String TOPIC_ID = "your-destination-topic";

    public static void main(String[] args) throws Exception {

        ProjectTopicName topicName =
                ProjectTopicName.of(PROJECT_ID, TOPIC_ID);

        Publisher publisher = Publisher.newBuilder(topicName).build();

        ProjectSubscriptionName subscriptionName =
                ProjectSubscriptionName.of(PROJECT_ID, SUBSCRIPTION_ID);

        MessageReceiver receiver = new MessageReceiver() {
            @Override
            public void receiveMessage(PubsubMessage message,
                                       AckReplyConsumer consumer) {

                try {

                    PubsubMessage newMessage =
                            PubsubMessage.newBuilder()
                                    .setData(message.getData())
                                    .putAllAttributes(message.getAttributesMap())
                                    .build();

                    ApiFuture<String> future = publisher.publish(newMessage);

                    String messageId = future.get();

                    System.out.println(
                            "Republished message: " + messageId);

                    consumer.ack();

                } catch (Exception e) {
                    e.printStackTrace();
                    consumer.nack();
                }
            }
        };

        Subscriber subscriber =
                Subscriber.newBuilder(subscriptionName, receiver).build();

        subscriber.startAsync().awaitRunning();

        System.out.println("Listening... Press Ctrl+C to stop.");

        Runtime.getRuntime().addShutdownHook(new Thread(() -> {
            System.out.println("Stopping...");
            subscriber.stopAsync();
            publisher.shutdown();
        }));

        subscriber.awaitTerminated();
    }
}