import org.junit.jupiter.api.Test;

import java.nio.file.Files;
import java.nio.file.Paths;
import java.util.regex.Matcher;
import java.util.regex.Pattern;

public class GenerateFieldMetadataTest {

    @Test
    void generateFields() throws Exception {

        String csvPath = "C:/temp/alter_commands.csv"; // Change path

        Pattern pattern = Pattern.compile(
                "ADD\\s+COLUMN\\s+(\\w+)\\s+([A-Z]+)(?:\\((\\d+)\\))?",
                Pattern.CASE_INSENSITIVE);

        Files.lines(Paths.get(csvPath))
                .filter(line -> !line.trim().isEmpty())
                .forEach(line -> {

                    Matcher matcher = pattern.matcher(line);

                    if (matcher.find()) {

                        String columnName = matcher.group(1);
                        String spannerType = matcher.group(2).toUpperCase();
                        String length = matcher.group(3);

                        String javaType = getJavaType(spannerType);

                        System.out.println(
                                "@FieldMetaData(datatype = \"" + javaType + "\"" +
                                        (length != null ? ", length = " + length : "") +
                                        ", actualFieldName = \"" + columnName + "\"" +
                                        ", description = \"" + columnName + " for Message\")");

                        System.out.println(
                                "private " + javaType + " " + columnName + ";");

                        System.out.println();
                    }
                });
    }

    private static String getJavaType(String spannerType) {
        switch (spannerType) {
            case "STRING":
                return "String";
            case "INT64":
                return "Long";
            case "FLOAT64":
                return "Double";
            case "BOOL":
            case "BOOLEAN":
                return "Boolean";
            case "TIMESTAMP":
                return "Timestamp";
            case "DATE":
                return "Date";
            case "NUMERIC":
                return "BigDecimal";
            case "BYTES":
                return "ByteArray";
            default:
                return "String";
        }
    }
}