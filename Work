import com.google.gson.*;
import com.google.protobuf.ByteString;

import java.lang.reflect.Type;

Gson gson = new GsonBuilder()
    .registerTypeAdapter(ByteString.class, new JsonSerializer<ByteString>() {
        @Override
        public JsonElement serialize(ByteString src, Type typeOfSrc,
                                     JsonSerializationContext context) {
            return new JsonPrimitive(src.toStringUtf8());
        }
    })
    .registerTypeAdapter(ByteString.class, new JsonDeserializer<ByteString>() {
        @Override
        public ByteString deserialize(JsonElement json, Type typeOfT,
                                      JsonDeserializationContext context) {
            return ByteString.copyFromUtf8(json.getAsString());
        }
    })
    .create();