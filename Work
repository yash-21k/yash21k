import org.junit.jupiter.api.Test;

import java.nio.file.Files;
import java.nio.file.Paths;
import java.util.ArrayList;
import java.util.List;

public class CsvMappingTest {

    @Test
    void generateMappings() throws Exception {

        String csv1File = "src/test/resources/csv1.csv";
        String csv2File = "src/test/resources/csv2.csv";

        List<String> list1 = new ArrayList<>();
        List<String> list2 = new ArrayList<>();

        // Read first CSV
        for (String line : Files.readAllLines(Paths.get(csv1File))) {
            for (String value : line.split(",")) {
                list1.add(value.trim());
            }
        }

        // Read second CSV
        for (String line : Files.readAllLines(Paths.get(csv2File))) {
            for (String value : line.split(",")) {
                list2.add(value.trim());
            }
        }

        // Print mappings
        for (int i = 0; i < Math.min(list1.size(), list2.size()); i++) {
            System.out.println("'" + list1.get(i) + "' : '" + list2.get(i) + "', \\");
        }
    }
}