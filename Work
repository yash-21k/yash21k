public static String extractXml(String source) {
    if (source == null || source.isBlank()) {
        return source;
    }

    int xmlStartIndex = source.indexOf("<?xml");
    if (xmlStartIndex == -1) {
        xmlStartIndex = source.indexOf("<");
    }

    if (xmlStartIndex == -1) {
        return source;
    }

    return source.substring(xmlStartIndex);
}