import com.google.cloud.pubsub.v1.Publisher;
import com.google.protobuf.ByteString;
import com.google.pubsub.v1.ProjectTopicName;
import com.google.pubsub.v1.PubsubMessage;

import java.util.UUID;
import java.util.concurrent.TimeUnit;

public class MultiTopicPublisher {

    // ===================== CONFIG =====================
    private static final String PROJECT_ID = "your-project-id";

    private static final String TOPIC_1 = "topic-1";
    private static final String TOPIC_2 = "topic-2";
    private static final String TOPIC_3 = "topic-3";
    private static final String TOPIC_4 = "topic-4";
    private static final String TOPIC_5 = "topic-5";
    private static final String TOPIC_6 = "topic-6";
    private static final String TOPIC_7 = "topic-7";
    private static final String TOPIC_8 = "topic-8";

    // Transaction flows per second
    private static final int TPS = 100;

    // Duration in minutes
    private static final int DURATION_MINUTES = 10;

    // Placeholder present in your payloads
    private static final String TXN_PLACEHOLDER = "{{TRANSACTION_ID}}";

    private static final String MESSAGE_TEMPLATE_1 =
            """
            {
              "transactionId":"{{TRANSACTION_ID}}",
              "engine":"AMH"
            }
            """;

    private static final String MESSAGE_TEMPLATE_2 =
            """
            {
              "transactionId":"{{TRANSACTION_ID}}",
              "engine":"GPE"
            }
            """;

    private static final String MESSAGE_TEMPLATE_3 =
            """
            {
              "transactionId":"{{TRANSACTION_ID}}",
              "engine":"POL"
            }
            """;

    private static final String MESSAGE_TEMPLATE_4 =
            """
            {
              "transactionId":"{{TRANSACTION_ID}}",
              "engine":"SWIFT"
            }
            """;

    private static final String MESSAGE_TEMPLATE_5 =
            """
            {
              "transactionId":"{{TRANSACTION_ID}}",
              "engine":"TDS"
            }
            """;

    private static final String MESSAGE_TEMPLATE_6 =
            """
            {
              "transactionId":"{{TRANSACTION_ID}}",
              "engine":"PO"
            }
            """;

    private static final String MESSAGE_TEMPLATE_7 =
            """
            {
              "transactionId":"{{TRANSACTION_ID}}",
              "engine":"CLIENT"
            }
            """;

    private static final String MESSAGE_TEMPLATE_8 =
            """
            {
              "transactionId":"{{TRANSACTION_ID}}",
              "engine":"NOTIFY"
            }
            """;
    // ==================================================

    public static void main(String[] args) throws Exception {

        Publisher publisher1 = Publisher.newBuilder(
                ProjectTopicName.of(PROJECT_ID, TOPIC_1)).build();

        Publisher publisher2 = Publisher.newBuilder(
                ProjectTopicName.of(PROJECT_ID, TOPIC_2)).build();

        Publisher publisher3 = Publisher.newBuilder(
                ProjectTopicName.of(PROJECT_ID, TOPIC_3)).build();

        Publisher publisher4 = Publisher.newBuilder(
                ProjectTopicName.of(PROJECT_ID, TOPIC_4)).build();

        Publisher publisher5 = Publisher.newBuilder(
                ProjectTopicName.of(PROJECT_ID, TOPIC_5)).build();

        Publisher publisher6 = Publisher.newBuilder(
                ProjectTopicName.of(PROJECT_ID, TOPIC_6)).build();

        Publisher publisher7 = Publisher.newBuilder(
                ProjectTopicName.of(PROJECT_ID, TOPIC_7)).build();

        Publisher publisher8 = Publisher.newBuilder(
                ProjectTopicName.of(PROJECT_ID, TOPIC_8)).build();

        try {

            for (int second = 0; second < DURATION_MINUTES * 60; second++) {

                long start = System.currentTimeMillis();

                for (int i = 0; i < TPS; i++) {

                    // Same UUID for all 8 messages
                    String transactionId = UUID.randomUUID().toString();

                    String message1 = MESSAGE_TEMPLATE_1.replace(TXN_PLACEHOLDER, transactionId);
                    String message2 = MESSAGE_TEMPLATE_2.replace(TXN_PLACEHOLDER, transactionId);
                    String message3 = MESSAGE_TEMPLATE_3.replace(TXN_PLACEHOLDER, transactionId);
                    String message4 = MESSAGE_TEMPLATE_4.replace(TXN_PLACEHOLDER, transactionId);
                    String message5 = MESSAGE_TEMPLATE_5.replace(TXN_PLACEHOLDER, transactionId);
                    String message6 = MESSAGE_TEMPLATE_6.replace(TXN_PLACEHOLDER, transactionId);
                    String message7 = MESSAGE_TEMPLATE_7.replace(TXN_PLACEHOLDER, transactionId);
                    String message8 = MESSAGE_TEMPLATE_8.replace(TXN_PLACEHOLDER, transactionId);

                    publisher1.publish(
                            PubsubMessage.newBuilder()
                                    .setData(ByteString.copyFromUtf8(message1))
                                    .build());

                    publisher2.publish(
                            PubsubMessage.newBuilder()
                                    .setData(ByteString.copyFromUtf8(message2))
                                    .build());

                    publisher3.publish(
                            PubsubMessage.newBuilder()
                                    .setData(ByteString.copyFromUtf8(message3))
                                    .build());

                    publisher4.publish(
                            PubsubMessage.newBuilder()
                                    .setData(ByteString.copyFromUtf8(message4))
                                    .build());

                    publisher5.publish(
                            PubsubMessage.newBuilder()
                                    .setData(ByteString.copyFromUtf8(message5))
                                    .build());

                    publisher6.publish(
                            PubsubMessage.newBuilder()
                                    .setData(ByteString.copyFromUtf8(message6))
                                    .build());

                    publisher7.publish(
                            PubsubMessage.newBuilder()
                                    .setData(ByteString.copyFromUtf8(message7))
                                    .build());

                    publisher8.publish(
                            PubsubMessage.newBuilder()
                                    .setData(ByteString.copyFromUtf8(message8))
                                    .build());
                }

                long elapsed = System.currentTimeMillis() - start;

                if (elapsed < 1000) {
                    Thread.sleep(1000 - elapsed);
                }

                System.out.println("Completed second " + (second + 1));
            }

        } finally {

            publisher1.shutdown();
            publisher2.shutdown();
            publisher3.shutdown();
            publisher4.shutdown();
            publisher5.shutdown();
            publisher6.shutdown();
            publisher7.shutdown();
            publisher8.shutdown();

            publisher1.awaitTermination(1, TimeUnit.MINUTES);
            publisher2.awaitTermination(1, TimeUnit.MINUTES);
            publisher3.awaitTermination(1, TimeUnit.MINUTES);
            publisher4.awaitTermination(1, TimeUnit.MINUTES);
            publisher5.awaitTermination(1, TimeUnit.MINUTES);
            publisher6.awaitTermination(1, TimeUnit.MINUTES);
            publisher7.awaitTermination(1, TimeUnit.MINUTES);
            publisher8.awaitTermination(1, TimeUnit.MINUTES);
        }

        System.out.println("Publishing completed.");
    }
}