import com.fasterxml.jackson.databind.JsonNode;
import com.fasterxml.jackson.databind.ObjectMapper;
import com.fasterxml.jackson.databind.node.ObjectNode;

import java.util.Iterator;
import java.util.Map;
import java.util.UUID;

public class UetrReplacer {

    private static final ObjectMapper mapper = new ObjectMapper();

    public static String replaceUetrWithRandomUUID(String json) throws Exception {
        JsonNode root = mapper.readTree(json);
        replaceRecursively(root);
        return mapper.writeValueAsString(root);
    }

    private static void replaceRecursively(JsonNode node) {
        if (node.isObject()) {
            ObjectNode obj = (ObjectNode) node;

            Iterator<Map.Entry<String, JsonNode>> fields = obj.fields();
            while (fields.hasNext()) {
                Map.Entry<String, JsonNode> entry = fields.next();

                if ("uetr".equalsIgnoreCase(entry.getKey())) {
                    obj.put(entry.getKey(), UUID.randomUUID().toString());
                } else {
                    replaceRecursively(entry.getValue());
                }
            }

        } else if (node.isArray()) {
            for (JsonNode element : node) {
                replaceRecursively(element);
            }
        }
    }

    // Example usage
    public static void main(String[] args) throws Exception {
        String json = "{\n" +
                "  \"uetr\": \"old\",\n" +
                "  \"payment\": {\n" +
                "    \"uetr\": \"old2\"\n" +
                "  },\n" +
                "  \"list\": [\n" +
                "    {\"uetr\": \"old3\"},\n" +
                "    {\"test\": \"value\"}\n" +
                "  ]\n" +
                "}";

        String updated = replaceUetrWithRandomUUID(json);
        System.out.println(updated);
    }
}